{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "woodpecker-ci": {
      "command": "node",
      "args": [
        ".claude/wp-mcp.cjs"
      ]
    }
  }
}
